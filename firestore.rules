rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable, hardened global helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    // Check if the user is a moderator or admin.
    // In our security system, we look up the /users/{userId} document to check their role.
    function isModerator() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'moderator';
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- USERS ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId) && 
                      incoming().uid == request.auth.uid && 
                      (incoming().role == 'user' || (request.auth.token.email == 'elmar.myspace@gmail.com' && incoming().role == 'moderator')) && // Force default role on signup to prevent privilege escalation
                      incoming().trust_level == 1; // Start trust level at 1
      allow update: if isSignedIn() && (
                      isOwner(userId) && 
                      incoming().role == existing().role && // Prevent role self-escalation
                      incoming().uid == existing().uid &&
                      incoming().diff(existing()).affectedKeys().hasOnly([
                        'name', 'phone', 'avatar', 'nationality', 'birthday', 
                        'allowBirthdayPublic', 'cars', 'interests', 'discoverableInterests', 'locations', 
                        'activeLocationId', 'district', 'address', 'is_verified', 
                        'trust_scores', 'trust_level'
                      ])
                    ) || isModerator() || isAdmin();
      allow delete: if isAdmin();
    }

    // --- POSTS ---
    function isValidPost(data) {
      return data.author is string && data.author.size() <= 100 &&
             data.content is string && data.content.size() <= 5000 &&
             data.type in ['feed', 'alert', 'question', 'free_stuff', 'lost_pet'] &&
             data.likes is int &&
             data.views is int &&
             data.clicks is int;
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidPost(incoming()) && incoming().authorId == request.auth.uid;
      allow update: if isSignedIn() && (
                      // Either author editing post content (only specific keys)
                      (incoming().authorId == request.auth.uid && 
                       incoming().authorId == existing().authorId &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['content', 'image', 'type', 'locationScope'])) ||
                      // Or anyone liking/viewing the post
                      incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'views', 'clicks']) ||
                      // Or moderator pinning/hiding
                      isModerator() || isAdmin()
                    );
      allow delete: if isSignedIn() && (existing().authorId == request.auth.uid || isModerator() || isAdmin());
      
      // --- COMMENTS ---
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn() && incoming().authorId == request.auth.uid && incoming().content is string && incoming().content.size() <= 1000;
        allow update: if isSignedIn() && (
                        (incoming().authorId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['content'])) ||
                        incoming().diff(existing()).affectedKeys().hasOnly(['reactions']) ||
                        isModerator() || isAdmin()
                      );
        allow delete: if isSignedIn() && (existing().authorId == request.auth.uid || isModerator() || isAdmin());
      }
    }

    // --- MOMENTS ---
    match /moments/{momentId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().authorId == request.auth.uid && incoming().image is string;
      allow update: if isSignedIn() && (
                      incoming().diff(existing()).affectedKeys().hasOnly(['reactions']) ||
                      isModerator() || isAdmin()
                    );
      allow delete: if isSignedIn() && (existing().authorId == request.auth.uid || isModerator() || isAdmin());
    }

    // --- CHATS ---
    match /chats/{chatId} {
      allow read, write: if isSignedIn(); // Broad access but restricted within individual participant lists if needed
      
      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && incoming().senderId == request.auth.uid;
        allow update: if isSignedIn() && (
                        (incoming().senderId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['text', 'reactions'])) ||
                        incoming().diff(existing()).affectedKeys().hasOnly(['reactions'])
                      );
        allow delete: if isSignedIn() && existing().senderId == request.auth.uid;
      }
    }

    // --- VERIFICATION REQUESTS ---
    match /verification_requests/{requestId} {
      allow read: if isSignedIn() && (existing().userId == request.auth.uid || isModerator() || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && incoming().status == 'pending';
      allow update: if isSignedIn() && (isModerator() || isAdmin());
      allow delete: if isAdmin();
    }

    // --- NOTIFICATIONS ---
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // --- REPORTS ---
    match /reports/{reportId} {
      allow read: if isSignedIn() && (isModerator() || isAdmin());
      allow create: if isSignedIn() && incoming().status == 'pending';
      allow update: if isSignedIn() && (isModerator() || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
